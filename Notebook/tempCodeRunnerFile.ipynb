import polars as pl
import pandas as pd
import datetime as dt

# =====================================================================
# CẤU HÌNH ĐƯỜNG DẪN DỮ LIỆU
# =====================================================================
# Hãy thay đổi đường dẫn này trỏ tới thư mục chứa các file dữ liệu của bạn
file_path = 'Data/*.csv'


print("=====================================================")
print(" PHẦN 1: THỐNG KÊ CHẤT LƯỢNG DỮ LIỆU BAN ĐẦU (DATA PROFILING)")
print("=====================================================")
print("Đang quét toàn bộ dữ liệu thô trên ổ cứng để kiểm tra lỗi...")

# Thiết lập luồng đọc lazy từ file thô ban đầu
lazy_raw = pl.scan_csv(file_path, ignore_errors=True)

# 1.1 Tính toán các thông số khuyết thiếu và lỗi hệ thống dựa trên EDA của bạn
raw_stats = lazy_raw.select([
    pl.len().alias("total_rows"),
    pl.col("user_session").null_count().alias("null_sessions"),
    pl.col("user_id").null_count().alias("null_users"),
    pl.col("brand").null_count().alias("null_brands"),
    pl.col("category_code").null_count().alias("null_categories"),
    (pl.col("price") <= 0).sum().alias("invalid_prices")
]).collect(engine="streaming")

total_raw_rows = raw_stats["total_rows"][0]
null_sess = raw_stats["null_sessions"][0]
null_users = raw_stats["null_users"][0]
null_brands = raw_stats["null_brands"][0]
null_cats = raw_stats["null_categories"][0]
invalid_pr = raw_stats["invalid_prices"][0]

print(f"✔️ Tổng số dòng dữ liệu thô ban đầu quét được: {total_raw_rows:,} dòng")
print(f"   ↳ Số dòng khuyết user_session: {null_sess:,} dòng ({null_sess/total_raw_rows*100:.4f}%)")
print(f"   ↳ Số dòng khuyết user_id: {null_users:,} dòng ({null_users/total_raw_rows*100:.4f}%)")
print(f"   ↳ Số dòng khuyết thương hiệu (brand): {null_brands:,} dòng ({null_brands/total_raw_rows*100:.2f}%)")
print(f"   ↳ Số dòng khuyết danh mục (category_code): {null_cats:,} dòng ({null_cats/total_raw_rows*100:.2f}%)")
print(f"   ↳ Số dòng có giá bị âm hoặc lỗi (price <= 0): {invalid_pr:,} dòng")

# 1.2 Tính toán số lượng dòng trùng lặp (Kỳ vọng ~5.2% dựa trên Slide của bạn)
print("Đang quét kiểm tra dữ liệu trùng lặp (Duplicates)...")
total_unique_rows = lazy_raw.unique().select(pl.len()).collect(engine="streaming").item()
duplicate_rows = total_raw_rows - total_unique_rows
print(f"   ↳ Số dòng trùng lặp hoàn toàn phát hiện: {duplicate_rows:,} dòng ({duplicate_rows/total_raw_rows*100:.2f}%)")


print("\n=====================================================")
print(" PHẦN 2: THỰC HIỆN TIỀN XỬ LÝ & LÀM SẠCH DỮ LIỆU THEO PHÂN TÍCH")
print("=====================================================")
print("Đang dọn dẹp dữ liệu ảo dưới nền (Lazy Clean)...")

# Bước 2.1: Xóa bỏ dữ liệu trùng lặp hoàn toàn (Xử lý lỗi mạng đúp click)
lazy_df = lazy_raw.unique()

# Bước 2.2: Lọc rác (Xóa bỏ dòng khuyết ID/Session và lọc bỏ giá âm lỗi hệ thống backend)
lazy_df = lazy_df.filter(
    pl.col("user_session").is_not_null() & 
    pl.col("user_id").is_not_null() &
    (pl.col("price") > 0)
)

# Bước 2.3: Loại bỏ (Drop) cột vô dụng: category_code (vì khuyết >98%, không thể học máy)
lazy_df = lazy_df.drop("category_code")

# Bước 2.4: Xử lý khuyết thiếu cột brand (Điền chữ unknown_brand cho 42% dòng bị trống)
lazy_df = lazy_df.with_columns([
    pl.col("brand").fill_null("unknown_brand")
])

# Bước 2.5: Chuẩn hóa thời gian (Cắt chuỗi bỏ chữ UTC ở 19 ký tự đầu để tránh lỗi múi giờ)
lazy_df = lazy_df.with_columns([
    pl.col("event_time")
    .str.slice(0, 19)
    .str.to_datetime(format="%Y-%m-%d %H:%M:%S")
    .alias("event_time")
]).with_columns([
    pl.col("event_time").dt.weekday().alias("day_of_week"),
    pl.col("event_time").dt.hour().alias("hour_of_day")
])


print("\n=====================================================")
print(" PHẦN 3: XÂY DỰNG ĐẶC TRƯNG HỌC MÁY (USER & SESSION LEVEL)")
print("=====================================================")
print("Đang tổng hợp các chỉ số hành vi ngắn hạn và lịch sử dài hạn...")

# 3.1 Tính toán bảng RFM (Chỉ thu thập từ các giao dịch mua hàng thực tế thành công)
lazy_rfm = (
    lazy_df.filter(pl.col("event_type") == "purchase")
    .group_by("user_id")
    .agg([
        pl.col("event_time").max().alias("last_purchase_date"),
        pl.col("user_session").n_unique().alias("Frequency"),
        pl.col("price").sum().alias("Monetary")
    ])
)

# 3.2 Tính toán đặc trưng cấp phiên (Loại bỏ hành vi purchase để tránh rò rỉ dữ liệu)
lazy_session = (
    lazy_df.filter(pl.col("event_type") != "purchase")
    .group_by("user_session")
    .agg([
        pl.col("user_id").first().alias("user_id"),
        pl.col("day_of_week").first().alias("day_of_week"),
        pl.col("hour_of_day").first().alias("hour_of_day"),
        
        # Đếm tần suất hành vi trong phiên lướt web
        (pl.col("event_type") == "view").sum().alias("total_views"),
        (pl.col("event_type") == "cart").sum().alias("total_carts"),
        (pl.col("event_type") == "remove_from_cart").sum().alias("total_removes"),
        
        # Thống kê phân phối giá và thời gian phiên
        (pl.col("event_time").max() - pl.col("event_time").min()).dt.total_seconds().alias("session_duration"),
        pl.col("price").mean().alias("avg_price"),
        pl.col("price").max().alias("max_price"),
        pl.col("product_id").n_unique().alias("unique_products"),
        
        # Đặc trưng thương hiệu
        pl.col("brand").n_unique().alias("unique_brands"),
        pl.col("brand").mode().first().alias("top_brand")
    ])
)

print("Kích hoạt Streaming Engine để cày và gom nhóm dữ liệu... (Vui lòng đợi)")
rfm_table = lazy_rfm.collect(engine="streaming")
session_table = lazy_session.collect(engine="streaming")

# Tạo danh sách các phiên có mua hàng làm nhãn đáp án (Target Label)
purchased_sessions = (
    lazy_df.filter(pl.col("event_type") == "purchase")
    .select("user_session").unique().collect(engine="streaming")
)["user_session"].to_list()

# Đo đếm khoảng cách thời gian Recency (số ngày kể từ lần mua cuối)
current_date = rfm_table["last_purchase_date"].max() + dt.timedelta(days=1)
rfm_table = rfm_table.with_columns([
    (current_date - pl.col("last_purchase_date")).dt.total_days().alias("Recency")
])


print("\n=====================================================")
print(" PHẦN 4: HỢP NHẤT DỮ LIỆU & MÃ HÓA ĐẶC TRƯNG (PANDAS)")
print("=====================================================")
print("Chuyển kết quả gọn nhẹ về Pandas phục vụ huấn luyện mô hình...")

df_rfm = rfm_table.to_pandas()
df_train = session_table.to_pandas()

# 4.1 Chấm điểm RFM dạng số nguyên (Thang điểm từ 1 -> 4 cho Machine Learning)
df_rfm['R_Score'] = pd.qcut(df_rfm['Recency'], q=4, labels=[4, 3, 2, 1]).astype(int)
df_rfm['F_Score'] = pd.qcut(df_rfm['Frequency'].rank(method='first'), q=4, labels=[1, 2, 3, 4]).astype(int)
df_rfm['M_Score'] = pd.qcut(df_rfm['Monetary'], q=4, labels=[1, 2, 3, 4]).astype(int)
df_rfm['RFM_Total_Score'] = df_rfm['R_Score'] + df_rfm['F_Score'] + df_rfm['M_Score']

# 4.2 Gắn nhãn mục tiêu (1: Có mua hàng, 0: Chỉ lướt xem rồi thoát)
df_train['is_purchased'] = df_train['user_session'].isin(purchased_sessions).astype(int)

# Thêm cột cờ: Xem khách có xu hướng tập trung so sánh hay chỉ trung thủy 1 brand duy nhất
df_train['is_single_brand'] = (df_train['unique_brands'] == 1).astype(int)

# Khớp nối lịch sử quá khứ của khách hàng vào phiên truy cập hiện tại
df_train = pd.merge(df_train, df_rfm[['user_id', 'R_Score', 'F_Score', 'M_Score', 'RFM_Total_Score']], on='user_id', how='left')

# Điền giá trị số 0 cho những tài khoản mới tinh (Vừa lập nick, chưa từng có lịch sử RFM quá khứ)
cols_to_fill = ['R_Score', 'F_Score', 'M_Score', 'RFM_Total_Score', 'avg_price', 'max_price']
df_train[cols_to_fill] = df_train[cols_to_fill].fillna(0)

# ---------------------------------------------------------
# 4.3 MÃ HÓA MỤC TIÊU (TARGET ENCODING) CHO CỘT THƯƠNG HIỆU
# ---------------------------------------------------------
print("Đang thực hiện Mã hóa Mục tiêu (Target Encoding) cho cột top_brand...")
# Tính tỷ lệ mua hàng trung bình của từng thương hiệu
brand_target_mean = df_train.groupby('top_brand')['is_purchased'].mean()

# Ánh xạ tỷ lệ này ngược lại vào bảng dữ liệu thành một cột dạng số mới
df_train['top_brand_encoded'] = df_train['top_brand'].map(brand_target_mean)

# Xóa bỏ cột 'top_brand' dạng chữ ban đầu vì máy học không đọc được chữ
df_train = df_train.drop(columns=['top_brand'])


print("\n=====================================================")
print(" 🎉 HOÀN THẤT! BỘ DỮ LIỆU SẠCH ĐÃ SẴN SÀNG CHO MÁY HỌC")
print("=====================================================")
print(f"📊 Tổng số phiên truy cập thu được (Số dòng): {df_train.shape[0]:,}")
print(f"📊 Tổng số đặc trưng đầu vào (Số cột): {df_train.shape[1]}")

# HIỂN THỊ KẾT QUẢ TRỰC QUAN TRÊN JUPYTER
display(df_train.head())

